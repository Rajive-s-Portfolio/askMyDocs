# ============================================
# Stripe Documentation RAG - Environment Config
# ============================================
# Copy this file to .env and adjust values as needed.
# The .env file is gitignored — never commit it.

# ---------- Source Configuration ----------
# URL of the Stripe llms.txt index file
STRIPE_LLMS_URL=https://docs.stripe.com/llms.txt

# ---------- Download Behavior ----------
# Max number of concurrent HTTP requests
DOWNLOAD_CONCURRENCY=5

# Politeness delay range between requests (seconds)
REQUEST_DELAY_MIN=0.5
REQUEST_DELAY_MAX=1.0

# HTTP request timeout (seconds)
HTTP_TIMEOUT=30

# HTTP connect timeout (seconds) — fail fast if server unreachable
HTTP_CONNECT_TIMEOUT=10

# User-Agent header for HTTP requests
HTTP_USER_AGENT='AskMyDocs/0.1 (educational; contact:rajivmailing@gmail.com)'

# ---------- Filesystem Paths ----------
# Where downloaded raw markdown files go
RAW_DATA_DIR=data/raw

# Where processed JSON outputs go
PROCESSED_DATA_DIR=data/processed

# Where logs are written
LOGS_DIR=logs

# ---------- Logging ----------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO